# Backend environment for api/upload-server.mjs.
# Keep the real api/.env private. SUPABASE_SERVICE_ROLE_KEY must never go to the frontend.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_private_service_role_key

API_PORT=8787
NODE_ENV=development
UPLOADS_DIR=public/uploads
PRIVATE_UPLOADS_DIR=private/uploads
# Public URL used to render files returned by this API.
PUBLIC_UPLOAD_BASE_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:5173
# Set only behind a trusted reverse proxy so rate limits use the real visitor IP.
# TRUST_PROXY_HOPS=1
# Identify the application when the backend consults OpenStreetMap/Nominatim.
GEOCODER_USER_AGENT=TatuApp/1.0 (contato@seudominio.com)
# Optional endpoint overrides for controlled testing or alternate providers.
# POSTAL_CODE_API_BASE_URL=https://viacep.com.br/ws
# POSTAL_COORDINATES_API_BASE_URL=https://brasilapi.com.br/api/cep/v2
# GEOCODER_API_BASE_URL=https://nominatim.openstreetmap.org
MAX_IMAGE_UPLOAD_BYTES=6291456
MAX_PROOF_UPLOAD_BYTES=10485760

PUBLIC_API_BASE_URL=http://localhost:8787
PUBLIC_APP_URL=http://localhost:5173
PLATFORM_MONTHLY_PRICE=49

# Mercado Pago is optional while InfinitePay is the selected checkout.
# Production credential. Leave empty in local testing unless testing the integration.
MERCADO_PAGO_ACCESS_TOKEN=
# Test credential shown in the Mercado Pago test credentials area.
MERCADO_PAGO_TEST_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_CHECKOUT_MODE=sandbox

# InfinitePay: use a handle and/or hosted checkout/subscription URLs.
INFINITEPAY_HANDLE=seu_handle_sem_arroba
INFINITEPAY_CHECKOUT_URL=
INFINITEPAY_SUBSCRIPTION_URL=
INFINITEPAY_PLAN_URL=
INFINITEPAY_WEBHOOK_URL=http://localhost:8787/api/infinitepay/webhook
# Optional override for automated tests or a controlled proxy.
# INFINITEPAY_API_BASE_URL=https://api.checkout.infinitepay.io
