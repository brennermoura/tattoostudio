# Frontend environment (Vite).
# Safe template only. Never place SUPABASE_SERVICE_ROLE_KEY here.

# Supabase is used by the browser for authentication/session only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Node/Express backend URL. For local development use http://localhost:8787.
VITE_UPLOAD_API_URL=http://localhost:8787

# Display/default price in the frontend.
VITE_PLATFORM_MONTHLY_PRICE=49

# Optional legacy external checkout record amount, in cents.
VITE_INFINITEPAY_CHECKOUT_AMOUNT_CENTS=4900
